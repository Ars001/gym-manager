# Copy this file to `.env` and fill in real values. Never commit .env.

# Server
PORT=4000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string (Supabase / Neon / local)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_manager

# Auth — used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe (platform-level key for now; per-tenant Stripe accounts can be added later)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email notifications via Resend (https://resend.com — free tier).
# Without a key, emails are silently skipped and the app works normally.
# EMAIL_FROM must be a verified sender/domain on your Resend account.
RESEND_API_KEY=
EMAIL_FROM=Gym Manager <onboarding@resend.dev>
